---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import portfolioThumbnail from '../assets/blog-placeholder-5.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const articles = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((p) => ({
		href: `/blog/${p.id}/`,
		title: p.data.title,
		pubDate: p.data.pubDate as Date | null,
		heroImage: p.data.heroImage,
		tags: p.data.tags ?? [],
	}));

const portfolioEntry = {
	href: '/portfolio/',
	title: 'My Portfolio',
	pubDate: null as Date | null,
	heroImage: portfolioThumbnail,
	tags: ['Portfolio'],
};

const feed = [portfolioEntry, ...articles];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="page-grid" role="main">
			<section class="intro-cell flex justify-end pr-5 py-8">
				<div class="flex flex-col items-end gap-5 sm:flex-row sm:items-center sm:gap-6">
					<!-- TODO: swap placeholder with <img src="/profile.jpg" alt="Maiso Kuba" class="h-[88px] w-[88px] shrink-0 rounded-full object-cover"> -->
					<div
						class="h-[88px] w-[88px] shrink-0 rounded-full border border-[#e5e5e5] bg-[#d9d9d9]"
						aria-hidden="true"
					></div>
					<p class="max-w-[360px] font-sans text-sm text-[#6b6b6b] text-right sm:text-left">
						My name is Maiso Kuba from Austria, I am a Network Engineer and CCNA certified.
					</p>
				</div>
			</section>
			<section class="feed-cell">
				<ul class="m-0 list-none p-0">
					{
						feed.map((item) => (
							<li class="border-b border-[#e5e5e5] last:border-b-0">
								<a
									href={item.href}
									class="group flex items-center gap-4 py-4 no-underline transition-colors hover:bg-[#f5f5f3]"
								>
									<div class="h-20 w-20 shrink-0 overflow-hidden rounded-md bg-[#e5e5e5]">
										{item.heroImage && (
											<Image
												src={item.heroImage}
												alt=""
												width={160}
												height={160}
												class="h-full w-full object-cover"
											/>
										)}
									</div>
									<div class="min-w-0 flex-1">
										<h3 class="m-0 font-mono text-base leading-snug text-site-black group-hover:text-[#ff6b4a]">
											{item.title}
										</h3>
										<div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-site-gray">
											{item.pubDate && <FormattedDate date={item.pubDate} />}
											{item.tags.length > 0 && (
												<span class="flex flex-wrap gap-2">
													{item.tags.map((t) => (
														<span class="text-[#ff6b4a]">#{t}</span>
													))}
												</span>
											)}
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</div>
		<Footer />
		<style>
			.page-grid {
				display: grid;
				grid-template-columns: 60% 1fr;
				grid-template-areas: 'feed intro';
				align-items: start;
			}
			.intro-cell {
				grid-area: intro;
			}
			.feed-cell {
				grid-area: feed;
				padding: 2em 1em 3em 50px;
			}
			@media (max-width: 720px) {
				.page-grid {
					grid-template-columns: 1fr;
					grid-template-areas:
						'intro'
						'feed';
				}
				.feed-cell {
					padding: 1em;
				}
			}
		</style>
	</body>
</html>
